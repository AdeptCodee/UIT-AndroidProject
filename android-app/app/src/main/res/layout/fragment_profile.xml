<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile &amp; Settings"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:layout_marginBottom="16dp"/>

        <!-- Banner Tím Gradient -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="180dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/profile_banner_gradient">

                <!-- Avatar -->
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="20dp"
                    android:src="@drawable/edit_text_bg"
                    app:civ_border_width="3dp"
                    app:civ_border_color="#FFFFFF"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/ivAvatar"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvDisplayNameHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User Tam"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvBioHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&gt;&gt;&gt; Dòng giới thiệu mặc định!! &lt;&lt;&lt;"
                        android:textColor="#E5E7EB"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Status Online -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:layout_margin="16dp"
                    android:background="@drawable/status_bg"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="● Online"
                    android:textColor="#10B981"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <!-- Form thông tin chi tiết -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thông tin cá nhân"
                    android:textStyle="bold"
                    android:textColor="#7C3AED"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tên hiển thị" android:layout_marginTop="16dp" android:textSize="12sp" android:textStyle="bold"/>
                <EditText android:id="@+id/etProfileDisplayName" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/edit_text_bg" android:padding="10dp" android:textSize="14sp" android:layout_marginTop="4dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Email" android:layout_marginTop="12dp" android:textSize="12sp" android:textStyle="bold"/>
                <EditText android:id="@+id/etProfileEmail" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/edit_text_bg" android:padding="10dp" android:textSize="14sp" android:layout_marginTop="4dp" android:enabled="false"/>

                <Button
                    android:id="@+id/btnUpdateProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lưu thay đổi"
                    android:backgroundTint="#7C3AED"
                    android:layout_marginTop="24dp"
                    android:textAllCaps="false"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>